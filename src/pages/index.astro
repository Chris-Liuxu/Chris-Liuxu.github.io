---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<nav>
			<a href="#hero" class="logo">Chris</a>
			<ul>
				<li><a href="#about">关于</a></li>
				<li><a href="#projects">项目</a></li>
				<li><a href="#contact">联系</a></li>
			</ul>
		</nav>

		<section id="hero">
			<p class="greeting">你好，我是</p>
			<h1>Chris Liu</h1>
			<p class="subtitle">软件工程师 · 产品设计爱好者</p>
			<div class="hero-actions">
				<a href="#projects" class="btn-primary">查看项目</a>
				<a href="#contact" class="btn-secondary">联系我</a>
			</div>
		</section>

		<section id="about">
			<h2>关于我</h2>
			<div class="about-content">
				<p>
					我是一名软件工程师，专注于前端开发与全栈应用。喜欢把复杂的问题简单化，
					在代码之外也对设计、阅读与摄影保持兴趣。
				</p>
				<p>
					平时乐于尝试新技术，也相信「好的工具应当让人专注于事情本身」。
					这里记录一些我做过的项目与想法，欢迎交流。
				</p>
				<ul class="tags">
					<li>TypeScript</li>
					<li>React</li>
					<li>Astro</li>
					<li>Node.js</li>
					<li>UI/UX</li>
				</ul>
			</div>
		</section>

		<section id="projects">
			<h2>项目</h2>
			<div class="project-list">
				<article class="project">
					<h3>项目一</h3>
					<p>项目简介占位文字，简短描述项目做了什么、解决了什么问题。</p>
					<a href="#" class="project-link">查看 →</a>
				</article>
				<article class="project">
					<h3>项目二</h3>
					<p>项目简介占位文字，简短描述项目做了什么、解决了什么问题。</p>
					<a href="#" class="project-link">查看 →</a>
				</article>
				<article class="project">
					<h3>项目三</h3>
					<p>项目简介占位文字，简短描述项目做了什么、解决了什么问题。</p>
					<a href="#" class="project-link">查看 →</a>
				</article>
			</div>
		</section>

		<section id="contact">
			<h2>联系</h2>
			<p>欢迎通过以下方式与我联系：</p>
			<ul class="contact-list">
				<li><span>Email</span><a href="mailto:hello@example.com">hello@example.com</a></li>
				<li><span>GitHub</span><a href="https://github.com/">@chris</a></li>
				<li><span>Twitter</span><a href="https://twitter.com/">@chris</a></li>
			</ul>
		</section>

		<footer>
			<p>© {new Date().getFullYear()} Chris. All rights reserved.</p>
		</footer>
	</main>
</Layout>

<style is:global>
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
			"Hiragino Sans GB", "Microsoft YaHei", sans-serif;
		line-height: 1.7;
		color: #1a1a1a;
		background: #fafafa;
		-webkit-font-smoothing: antialiased;
	}

	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 24px;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 24px 0;
	}

	nav .logo {
		font-weight: 600;
		font-size: 18px;
		text-decoration: none;
		color: #1a1a1a;
		letter-spacing: -0.01em;
	}

	nav ul {
		display: flex;
		list-style: none;
		gap: 28px;
	}

	nav a {
		text-decoration: none;
		color: #555;
		font-size: 15px;
		transition: color 0.2s ease;
	}

	nav a:hover {
		color: #1a1a1a;
	}

	#hero {
		padding: 120px 0 80px;
	}

	.greeting {
		color: #888;
		font-size: 15px;
		margin-bottom: 12px;
	}

	#hero h1 {
		font-size: clamp(40px, 8vw, 64px);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin-bottom: 16px;
	}

	.subtitle {
		font-size: 18px;
		color: #555;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.btn-primary,
	.btn-secondary {
		display: inline-block;
		padding: 12px 24px;
		border-radius: 8px;
		text-decoration: none;
		font-size: 15px;
		font-weight: 500;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: #1a1a1a;
		color: #fff;
	}

	.btn-primary:hover {
		background: #333;
	}

	.btn-secondary {
		background: transparent;
		color: #1a1a1a;
		border: 1px solid #d4d4d4;
	}

	.btn-secondary:hover {
		border-color: #1a1a1a;
	}

	section {
		padding: 64px 0;
		border-top: 1px solid #eaeaea;
	}

	section h2 {
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin-bottom: 24px;
	}

	.about-content p {
		color: #444;
		margin-bottom: 16px;
		font-size: 16px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 24px;
		list-style: none;
	}

	.tags li {
		padding: 6px 14px;
		background: #f0f0f0;
		border-radius: 999px;
		font-size: 13px;
		color: #555;
	}

	.project-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 24px;
	}

	.project {
		padding: 24px;
		background: #fff;
		border: 1px solid #eaeaea;
		border-radius: 12px;
		transition: all 0.2s ease;
	}

	.project:hover {
		border-color: #d4d4d4;
		transform: translateY(-2px);
	}

	.project h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.project p {
		color: #555;
		font-size: 15px;
		margin-bottom: 16px;
	}

	.project-link {
		font-size: 14px;
		color: #1a1a1a;
		text-decoration: none;
		font-weight: 500;
	}

	.project-link:hover {
		text-decoration: underline;
	}

	#contact p {
		color: #555;
		margin-bottom: 20px;
	}

	.contact-list {
		list-style: none;
	}

	.contact-list li {
		display: flex;
		gap: 20px;
		padding: 14px 0;
		border-bottom: 1px solid #eaeaea;
	}

	.contact-list li:last-child {
		border-bottom: none;
	}

	.contact-list span {
		min-width: 80px;
		color: #888;
		font-size: 14px;
	}

	.contact-list a {
		color: #1a1a1a;
		text-decoration: none;
		font-size: 15px;
	}

	.contact-list a:hover {
		text-decoration: underline;
	}

	footer {
		padding: 48px 0 32px;
		text-align: center;
		color: #999;
		font-size: 13px;
		border-top: 1px solid #eaeaea;
	}

	@media (max-width: 600px) {
		#hero {
			padding: 80px 0 60px;
		}

		nav ul {
			gap: 20px;
		}

		section {
			padding: 48px 0;
		}

		.contact-list li {
			flex-direction: column;
			gap: 4px;
		}

		.contact-list span {
			min-width: auto;
		}
	}
</style>